        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT strategy, pipeline_id, COUNT(*) AS runs, SUM(read_count) AS total_read_count, SUM(insert_count + update_count + delete_count) AS total_change_count, SUM(artifact_total_bytes) AS artifact_total_bytes, ROUND(AVG(run_duration_seconds)::numeric, 2) AS avg_run_duration_seconds FROM ingestion_meta.v_run_metrics WHERE started_at >= now() - interval '24 hours' GROUP BY 1, 2 ORDER BY artifact_total_bytes DESC, total_read_count DESC LIMIT 25;",
          "refId": "A"
        }
      ],
      "title": "Top Pipelines By Load (24h)",
      "type": "table"
